# Copy this file to .env and adjust values for your local environment.
# The .env file is loaded automatically by many shell setups; alternatively,
# export the variables in your shell before starting the server.

# Set to "development" to allow JWT cookies over plain HTTP (Secure=False).
# In all other environments cookies require HTTPS (Secure=True).
FLASK_ENV=development
RESEND_API_KEY=ExampleApiKey123